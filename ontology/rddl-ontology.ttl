@prefix : <http://www.semanticweb.org/put/database-data-lineage#> .
@prefix dsd: <https://w3id.org/dsd#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix csvw: <http://www.w3.org/ns/csvw#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <http://www.semanticweb.org/put/database-data-lineage#> .

<http://www.semanticweb.org/put/database-data-lineage> rdf:type owl:Ontology .

#################################################################
#    Object Properties
#################################################################

###  http://www.semanticweb.org/put/database-data-lineage#belongsToColumn
:belongsToColumn rdf:type owl:ObjectProperty ;
                 owl:inverseOf :hasInstance ;
                 rdfs:domain :ColumnValue ;
                 rdfs:range :Column .


###  http://www.semanticweb.org/put/database-data-lineage#columnDerivedFrom
:columnDerivedFrom rdf:type owl:ObjectProperty ;
                   rdfs:subPropertyOf prov:wasDerivedFrom ;
                   rdfs:domain :Column ;
                   rdfs:range :Column .


###  http://www.semanticweb.org/put/database-data-lineage#executesFunction
:executesFunction rdf:type owl:ObjectProperty ;
                  rdfs:subPropertyOf prov:hadPlan ;
                  rdfs:domain :FuncExecution ;
                  rdfs:range :Function .


###  http://www.semanticweb.org/put/database-data-lineage#executesProcedure
:executesProcedure rdf:type owl:ObjectProperty ;
                   rdfs:subPropertyOf prov:hadPlan ;
                   rdfs:domain :ProcExecution ;
                   rdfs:range :Procedure .


###  http://www.semanticweb.org/put/database-data-lineage#executesQuery
:executesQuery rdf:type owl:ObjectProperty ;
               rdfs:subPropertyOf prov:hadPlan ;
               rdfs:domain :QueryExecution ;
               rdfs:range :Query .


###  http://www.semanticweb.org/put/database-data-lineage#generatesRow
:generatesRow rdf:type owl:ObjectProperty ;
              rdfs:subPropertyOf prov:generated ;
              rdfs:domain :Execution ;
              rdfs:range :TargetDataCandidate .


###  http://www.semanticweb.org/put/database-data-lineage#hasCellValue
:hasCellValue rdf:type owl:ObjectProperty ;
              rdfs:domain :Row ;
              rdfs:range :ColumnValue .


###  http://www.semanticweb.org/put/database-data-lineage#hasColumn
:hasColumn rdf:type owl:ObjectProperty ;
           rdfs:subPropertyOf dsd:hasAttribute ;
           owl:inverseOf :isColumnOf ;
           rdfs:domain :Table ;
           rdfs:range :Column .


###  http://www.semanticweb.org/put/database-data-lineage#hasConstraint
:hasConstraint rdf:type owl:ObjectProperty ;
               rdfs:domain :Column ;
               rdfs:range :Constraint .


###  http://www.semanticweb.org/put/database-data-lineage#hasDatatype
:hasDatatype rdf:type owl:ObjectProperty ;
             rdfs:subPropertyOf csvw:datatype ;
             rdfs:domain :Column ;
             rdfs:range :DataType .


###  http://www.semanticweb.org/put/database-data-lineage#hasInstance
:hasInstance rdf:type owl:ObjectProperty ;
             rdfs:domain :Column ;
             rdfs:range :ColumnValue .


###  http://www.semanticweb.org/put/database-data-lineage#hasRow
:hasRow rdf:type owl:ObjectProperty ;
        rdfs:subPropertyOf csvw:row ;
        rdfs:domain :Table ;
        rdfs:range :Row .


###  http://www.semanticweb.org/put/database-data-lineage#isColumnOf
:isColumnOf rdf:type owl:ObjectProperty ;
            rdfs:subPropertyOf dsd:isAttributeOf ;
            rdfs:domain :Column ;
            rdfs:range :Table .


###  http://www.semanticweb.org/put/database-data-lineage#referencesColumn
:referencesColumn rdf:type owl:ObjectProperty ;
                  rdfs:domain :ForeignKey ;
                  rdfs:range :Column .


###  http://www.semanticweb.org/put/database-data-lineage#rowDerivedFrom
:rowDerivedFrom rdf:type owl:ObjectProperty ;
                rdfs:subPropertyOf prov:wasDerivedFrom ;
                rdfs:domain :Row ;
                rdfs:range :Row .


###  http://www.semanticweb.org/put/database-data-lineage#tableDerivedFrom
:tableDerivedFrom rdf:type owl:ObjectProperty ;
                  rdfs:subPropertyOf prov:wasDerivedFrom ;
                  rdfs:domain :SourceDataCandidate ;
                  rdfs:range :TargetDataCandidate .


###  http://www.semanticweb.org/put/database-data-lineage#usesTable
:usesTable rdf:type owl:ObjectProperty ;
           rdfs:subPropertyOf prov:used ;
           rdfs:domain :Execution ;
           rdfs:range :SourceDataCandidate .


###  http://www.semanticweb.org/put/database-data-lineage#valueDerivedFrom
:valueDerivedFrom rdf:type owl:ObjectProperty ;
                  rdfs:subPropertyOf prov:wasDerivedFrom ;
                  rdfs:domain :ColumnValue ;
                  rdfs:range :ColumnValue .


###  http://www.semanticweb.org/put/database-data-lineage#wasUsedForCreation
:wasUsedForCreation rdf:type owl:ObjectProperty ;
                    rdfs:domain :Query ;
                    rdfs:range :View .


###  http://www.w3.org/ns/csvw#datatype
csvw:datatype rdf:type owl:ObjectProperty ;
              rdfs:domain <http://w3c.github.io/csvw/ns/Column> ;
              rdfs:range csvw:Datatype ;
              rdfs:label "csvw:datatype" .


###  http://www.w3.org/ns/csvw#row
csvw:row rdf:type owl:ObjectProperty ;
         rdfs:domain <http://w3c.github.io/csvw/ns/Table> ;
         rdfs:range <http://w3c.github.io/csvw/ns/Row> ;
         rdfs:label "csvw:row" .


###  http://www.w3.org/ns/prov#generated
prov:generated rdf:type owl:ObjectProperty .


###  http://www.w3.org/ns/prov#hadPlan
prov:hadPlan rdf:type owl:ObjectProperty .


###  http://www.w3.org/ns/prov#used
prov:used rdf:type owl:ObjectProperty .


###  http://www.w3.org/ns/prov#wasDerivedFrom
prov:wasDerivedFrom rdf:type owl:ObjectProperty ,
                             owl:TransitiveProperty ;
                    rdfs:label "prov:wasDerivedFrom" .


###  https://w3id.org/dsd#hasAttribute
dsd:hasAttribute rdf:type owl:ObjectProperty ;
                 owl:inverseOf dsd:isAttributeOf ;
                 rdfs:domain dsd:Concept ;
                 rdfs:range dsd:Attribute ;
                 rdfs:label "dsd:hasAttribute" .


###  https://w3id.org/dsd#isAttributeOf
dsd:isAttributeOf rdf:type owl:ObjectProperty ;
                  rdfs:domain dsd:Attribute ;
                  rdfs:range dsd:Concept ;
                  rdfs:label "dsd:isAttributeOf" .


#################################################################
#    Data properties
#################################################################

###  http://www.semanticweb.org/put/database-data-lineage#columnName
:columnName rdf:type owl:DatatypeProperty ;
            rdfs:subPropertyOf csvw:name ;
            rdf:type owl:FunctionalProperty ;
            rdfs:domain :Column ;
            rdfs:range xsd:string .


###  http://www.semanticweb.org/put/database-data-lineage#datatypeName
:datatypeName rdf:type owl:DatatypeProperty ;
              rdfs:domain :DataType ;
              rdfs:range xsd:string .


###  http://www.semanticweb.org/put/database-data-lineage#exactValue
:exactValue rdf:type owl:DatatypeProperty ,
                     owl:FunctionalProperty ;
            rdfs:domain :ColumnValue ;
            rdfs:range xsd:string .


###  http://www.semanticweb.org/put/database-data-lineage#isNullable
:isNullable rdf:type owl:DatatypeProperty ,
                     owl:FunctionalProperty ;
            rdfs:domain :Column ;
            rdfs:range xsd:boolean .


###  http://www.semanticweb.org/put/database-data-lineage#isUnique
:isUnique rdf:type owl:DatatypeProperty ,
                   owl:FunctionalProperty ;
          rdfs:domain :Column ;
          rdfs:range xsd:boolean .


###  http://www.semanticweb.org/put/database-data-lineage#name
:name rdf:type owl:DatatypeProperty ;
      rdfs:subPropertyOf csvw:name ;
      rdfs:domain :NamedDbObject ;
      rdfs:range xsd:string .


###  http://www.semanticweb.org/put/database-data-lineage#rownum
:rownum rdf:type owl:DatatypeProperty ;
        rdfs:subPropertyOf <http://www/w3/org/ns/csvw#rownum> ;
        rdf:type owl:FunctionalProperty ;
        rdfs:domain :Row ;
        rdfs:range xsd:integer .


###  http://www.semanticweb.org/put/database-data-lineage#title
:title rdf:type owl:DatatypeProperty ;
       rdfs:subPropertyOf csvw:title ;
       rdf:type owl:FunctionalProperty ;
       rdfs:domain :Table ;
       rdfs:range xsd:string .


###  http://www.semanticweb.org/put/database-data-lineage#typeLength
:typeLength rdf:type owl:DatatypeProperty ,
                     owl:FunctionalProperty ;
            rdfs:domain :DataType ;
            rdfs:range xsd:integer .


###  http://www.w3.org/ns/csvw#name
csvw:name rdf:type owl:DatatypeProperty ;
          rdfs:domain <http://w3c.github.io/csvw/ns/Column> ;
          rdfs:range xsd:string ;
          rdfs:label "csvw:name" .


###  http://www.w3.org/ns/csvw#title
csvw:title rdf:type owl:DatatypeProperty ;
           rdfs:domain <http://w3c.github.io/csvw/ns/Table> ;
           rdfs:range xsd:string ;
           rdfs:label "csvw:title" .


###  http://www/w3/org/ns/csvw#rownum
<http://www/w3/org/ns/csvw#rownum> rdf:type owl:DatatypeProperty ;
                                   rdfs:domain <http://w3c.github.io/csvw/ns/Row> ;
                                   rdfs:range xsd:integer ;
                                   rdfs:label "csvw:rownum" .


