###  http://w3c.github.io/csvw/ns/Cell
<http://w3c.github.io/csvw/ns/Cell> rdf:type owl:Class ;
                                    rdfs:label "csvw:Cell" .


###  http://w3c.github.io/csvw/ns/Column
<http://w3c.github.io/csvw/ns/Column> rdf:type owl:Class ;
                                      rdfs:label "csvw:Column" .


###  http://w3c.github.io/csvw/ns/Row
<http://w3c.github.io/csvw/ns/Row> rdf:type owl:Class ;
                                   rdfs:label "csvw:Row" .


###  http://w3c.github.io/csvw/ns/Table
<http://w3c.github.io/csvw/ns/Table> rdf:type owl:Class ;
                                     rdfs:label "csvw:Table" .


###  http://www.semanticweb.org/put/database-data-lineage#BooleanType
:BooleanType rdf:type owl:Class ;
             rdfs:subClassOf :DataType .


###  http://www.semanticweb.org/put/database-data-lineage#CheckConstraint
:CheckConstraint rdf:type owl:Class ;
                 rdfs:subClassOf :Constraint .


###  http://www.semanticweb.org/put/database-data-lineage#Column
:Column rdf:type owl:Class ;
        rdfs:subClassOf <http://w3c.github.io/csvw/ns/Column> ,
                        :DatabaseDataLineageConcept ,
                        prov:Entity ,
                        dsd:Attribute .


###  http://www.semanticweb.org/put/database-data-lineage#ColumnValue
:ColumnValue rdf:type owl:Class ;
             rdfs:subClassOf <http://w3c.github.io/csvw/ns/Cell> ,
                             :DatabaseDataLineageConcept .


###  http://www.semanticweb.org/put/database-data-lineage#Constraint
:Constraint rdf:type owl:Class ;
            rdfs:subClassOf :DatabaseDataLineageConcept .


###  http://www.semanticweb.org/put/database-data-lineage#DataType
:DataType rdf:type owl:Class ;
          rdfs:subClassOf :DatabaseDataLineageConcept ,
                          csvw:Datatype .


###  http://www.semanticweb.org/put/database-data-lineage#DatabaseDataLineageConcept
:DatabaseDataLineageConcept rdf:type owl:Class ;
                            rdfs:label "Database Data Linage Concept" .


###  http://www.semanticweb.org/put/database-data-lineage#DateTimeType
:DateTimeType rdf:type owl:Class ;
              rdfs:subClassOf :DataType .


###  http://www.semanticweb.org/put/database-data-lineage#Execution
:Execution rdf:type owl:Class ;
           rdfs:subClassOf prov:Activity .


###  http://www.semanticweb.org/put/database-data-lineage#ExternalTable
:ExternalTable rdf:type owl:Class ;
               rdfs:subClassOf :SourceDataCandidate ,
                               :TabularDataObject .


###  http://www.semanticweb.org/put/database-data-lineage#ForeignKey
:ForeignKey rdf:type owl:Class ;
            rdfs:subClassOf :Constraint .


###  http://www.semanticweb.org/put/database-data-lineage#FuncExecution
:FuncExecution rdf:type owl:Class ;
               rdfs:subClassOf :Execution .


###  http://www.semanticweb.org/put/database-data-lineage#Function
:Function rdf:type owl:Class ;
          rdfs:subClassOf :StoredCode .


###  http://www.semanticweb.org/put/database-data-lineage#MaterializedView
:MaterializedView rdf:type owl:Class ;
                  rdfs:subClassOf :SourceDataCandidate ,
                                  :TabularDataObject ,
                                  :TargetDataCandidate .


###  http://www.semanticweb.org/put/database-data-lineage#NamedDbObject
:NamedDbObject rdf:type owl:Class ;
               rdfs:subClassOf :DatabaseDataLineageConcept .


###  http://www.semanticweb.org/put/database-data-lineage#NotNullConstraint
:NotNullConstraint rdf:type owl:Class ;
                   rdfs:subClassOf :Constraint .


###  http://www.semanticweb.org/put/database-data-lineage#NumericType
:NumericType rdf:type owl:Class ;
             rdfs:subClassOf :DataType .


###  http://www.semanticweb.org/put/database-data-lineage#Package
:Package rdf:type owl:Class ;
         rdfs:subClassOf :StoredCode .


###  http://www.semanticweb.org/put/database-data-lineage#PrimaryKey
:PrimaryKey rdf:type owl:Class ;
            rdfs:subClassOf :Constraint .


###  http://www.semanticweb.org/put/database-data-lineage#ProcExecution
:ProcExecution rdf:type owl:Class ;
               rdfs:subClassOf :Execution .


###  http://www.semanticweb.org/put/database-data-lineage#Procedure
:Procedure rdf:type owl:Class ;
           rdfs:subClassOf :StoredCode .


###  http://www.semanticweb.org/put/database-data-lineage#Query
:Query rdf:type owl:Class ;
       rdfs:subClassOf :SourceDataCandidate .


###  http://www.semanticweb.org/put/database-data-lineage#QueryExecution
:QueryExecution rdf:type owl:Class ;
                rdfs:subClassOf :Execution .


###  http://www.semanticweb.org/put/database-data-lineage#Row
:Row rdf:type owl:Class ;
     rdfs:subClassOf <http://w3c.github.io/csvw/ns/Row> ,
                     :DatabaseDataLineageConcept ,
                     prov:Entity .


###  http://www.semanticweb.org/put/database-data-lineage#SourceDataCandidate
:SourceDataCandidate rdf:type owl:Class ;
                     rdfs:subClassOf :DatabaseDataLineageConcept .


###  http://www.semanticweb.org/put/database-data-lineage#StoredCode
:StoredCode rdf:type owl:Class ;
            rdfs:subClassOf :NamedDbObject ,
                            :SourceDataCandidate .


###  http://www.semanticweb.org/put/database-data-lineage#StringType
:StringType rdf:type owl:Class ;
            rdfs:subClassOf :DataType .


###  http://www.semanticweb.org/put/database-data-lineage#Table
:Table rdf:type owl:Class ;
       rdfs:subClassOf <http://w3c.github.io/csvw/ns/Table> ,
                       :SourceDataCandidate ,
                       :TabularDataObject ,
                       :TargetDataCandidate ,
                       prov:Entity ,
                       dsd:Concept .


###  http://www.semanticweb.org/put/database-data-lineage#TabularDataObject
:TabularDataObject rdf:type owl:Class ;
                   rdfs:subClassOf :NamedDbObject .


###  http://www.semanticweb.org/put/database-data-lineage#TargetDataCandidate
:TargetDataCandidate rdf:type owl:Class ;
                     rdfs:subClassOf :DatabaseDataLineageConcept .


###  http://www.semanticweb.org/put/database-data-lineage#TemporalTable
:TemporalTable rdf:type owl:Class ;
               rdfs:subClassOf :SourceDataCandidate ,
                               :TabularDataObject ,
                               :TargetDataCandidate .


###  http://www.semanticweb.org/put/database-data-lineage#UniqueConstraint
:UniqueConstraint rdf:type owl:Class ;
                  rdfs:subClassOf :Constraint .


###  http://www.semanticweb.org/put/database-data-lineage#View
:View rdf:type owl:Class ;
      rdfs:subClassOf :SourceDataCandidate ,
                      :TabularDataObject ,
                      :TargetDataCandidate .


###  http://www.w3.org/ns/csvw#Datatype
csvw:Datatype rdf:type owl:Class ;
              rdfs:label "csvw:DataType" .


###  http://www.w3.org/ns/prov#Activity
prov:Activity rdf:type owl:Class .


###  http://www.w3.org/ns/prov#Entity
prov:Entity rdf:type owl:Class .


###  https://w3id.org/dsd#Attribute
dsd:Attribute rdf:type owl:Class ;
              rdfs:label "dsd:Attribute" .


###  https://w3id.org/dsd#Concept
dsd:Concept rdf:type owl:Class ;
            rdfs:label "dsd:Concept" .


