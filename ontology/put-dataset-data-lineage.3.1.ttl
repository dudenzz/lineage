###  http://www.semanticweb.org/put/database-data-lineage#columnDerivedFrom
:columnDerivedFrom rdf:type owl:ObjectProperty ;
                   rdfs:subPropertyOf prov:wasDerivedFrom ;
                   rdfs:domain :Column ;
                   rdfs:range :Column .


